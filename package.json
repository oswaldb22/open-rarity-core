{
  "name": "open-rarity-core",
  "version": "0.1.0",
  "description": "Zero-dependency NFT rarity scoring using Information Content (IC) with Shannon entropy normalization",
  "keywords": [
    "nft",
    "rarity",
    "openrarity",
    "open-rarity",
    "typescript",
    "javascript",
    "browser",
    "ranking"
  ],
  "homepage": "https://github.com/oswaldb22/openrarityjs#readme",
  "bugs": {
    "url": "https://github.com/oswaldb22/openrarityjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oswaldb22/openrarityjs.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm test && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0"
}
